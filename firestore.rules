rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAuth() {
      return request.auth != null;
    }

    match /classes/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /chapters/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /worksheets/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quizzes/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isAuth() && (request.auth.uid == userId || isAdmin());
    }

    match /user_progress/{progressId} {
      // Need to handle both read existing and create new
      allow read, write: if isAuth() && (request.auth.uid == progressId || isAdmin());
    }

    match /quiz_attempts/{attemptId} {
      allow read: if isAuth() && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if isAuth() && (request.auth.uid == request.resource.data.userId || isAdmin());
    }
  }
}
